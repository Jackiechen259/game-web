# ─────────────────────────────────────────────────────────────
# Public
# ─────────────────────────────────────────────────────────────
PUBLIC_SITE_URL=https://games.example.com
PUBLIC_ADMIN_URL=https://games.example.com

# ─────────────────────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────────────────────
# "github" for GitHub OAuth, or "dev" to enable a single dev admin (non-production).
AUTH_PROVIDER=github
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Random 32+ byte hex string used to sign session cookies.
SESSION_SECRET=
# Comma-separated GitHub logins allowed into the admin.
ADMIN_GITHUB_USERS=bohanchen
ADMIN_SESSION_MAX_AGE_SECONDS=28800

# Dev-only single admin (used when AUTH_PROVIDER=dev). Never enable in production.
DEV_ADMIN_LOGIN=admin
DEV_ADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────────
# GitHub App (server-side only — never expose to the browser)
# ─────────────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# PEM-formatted private key. Use newline escapes or a file path via GITHUB_APP_PRIVATE_KEY_FILE.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_FILE=

# Optional override token used by the sync script for private repos / rate limits.
GITHUB_TOKEN=

# ─────────────────────────────────────────────────────────────
# Repositories
# ─────────────────────────────────────────────────────────────
GITHUB_GAME_LIBRARY_REPO=owner/web-games-library
GITHUB_PORTAL_REPO=owner/game-portal
GITHUB_SOURCE_BRANCH=main
GITHUB_DRAFT_BRANCH=admin/drafts
GITHUB_DIST_BRANCH=dist
GITHUB_PUBLISH_BRANCH_PREFIX=admin/publish-

# ─────────────────────────────────────────────────────────────
# Publishing
# ─────────────────────────────────────────────────────────────
# "pull-request" (production default) or "direct" (dev/test only).
ADMIN_PUBLISH_MODE=pull-request
PORTAL_DISPATCH_EVENT=games-library-updated

# ─────────────────────────────────────────────────────────────
# Portal game sync (build-time)
# ─────────────────────────────────────────────────────────────
GAMES_REPO=owner/web-games-library
GAMES_REF=dist
GAMES_CATALOG_PATH=catalog.json
GAMES_SYNC_ENABLED=true
# Local filesystem path to a built games library dist (skips GitHub download).
GAMES_LOCAL_PATH=
GAMES_MAX_ARCHIVE_SIZE_MB=500
GAMES_ALLOW_STALE_CACHE=false

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
DATABASE_URL=

# ─────────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────────
ADMIN_ALLOWED_ORIGINS=https://games.example.com
ADMIN_RATE_LIMIT_PER_MINUTE=60
ADMIN_MAX_UPLOAD_MB=5
PREVIEW_TOKEN_TTL_SECONDS=3600

# ─────────────────────────────────────────────────────────────
# Server runtime
# ─────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
